#!/usr/bin/env node

import os from "node:os";
import { execSync } from "node:child_process";
import { parseArgs } from "node:util";
import { startStdioServer } from "../dist/index.js";
import { detectCLITools, formatDetectedTools } from "../dist/cli/detect.js";
import { detectAndSetupOpenClaw } from "../dist/cli/openclaw.js";
import { loadDefaultCredential } from "../dist/core/config.js";
import { executePairing } from "../dist/core/pair.js";
import { launchCLI } from "../dist/cli/spawn.js";

const DEFAULT_ENDPOINT = "https://api.zhihand.com";

const CLI_TOOL_MAP = {
  claude: "claudecode",
  codex: "codex",
  gemini: "gemini",
};

const { positionals, values } = parseArgs({
  allowPositionals: true,
  strict: false,
  options: {
    device: { type: "string" },
    model: { type: "string" },
    http: { type: "boolean", default: false },
    help: { type: "boolean", short: "h", default: false },
  },
});

const command = positionals[0] ?? "serve";

if (values.help) {
  console.log(`
zhihand — MCP Server for phone control

Usage:
  zhihand serve              Start MCP Server (stdio mode)
  zhihand serve --http       Start MCP Server (HTTP mode)
  zhihand pair               Pair with a phone device
  zhihand status             Show pairing status and device info
  zhihand detect             Detect available CLI tools
  zhihand setup              Interactive setup: pair + configure

  zhihand claude [prompt]    Launch Claude Code with prompt
  zhihand codex [prompt]     Launch Codex CLI with prompt
  zhihand gemini [prompt]    Launch Gemini CLI (interactive mode)

Options:
  --device <name>    Use a specific paired device
  --model <model>    Specify model (e.g. zhihand gemini --model flash)
  -h, --help         Show this help
`);
  process.exit(0);
}

// Handle CLI tool subcommands: claude, codex, gemini
if (command in CLI_TOOL_MAP) {
  const toolName = CLI_TOOL_MAP[command];
  const tools = await detectCLITools();
  const tool = tools.find((t) => t.name === toolName);

  if (!tool) {
    console.error(`Error: ${command} is not installed or not found in PATH.`);
    console.error(`Install it first, then try again.`);
    process.exit(1);
  }

  const prompt = positionals.slice(1).join(" ");
  if (!prompt) {
    console.error(`Usage: zhihand ${command} <prompt>`);
    console.error(`Example: zhihand ${command} "take a screenshot of my phone"`);
    process.exit(1);
  }

  try {
    const code = await launchCLI(tool, prompt, { model: values.model });
    process.exit(code);
  } catch (err) {
    console.error(`Error running ${command}: ${err.message}`);
    process.exit(1);
  }
}

switch (command) {
  case "serve": {
    await startStdioServer(values.device ?? process.env.ZHIHAND_DEVICE);
    break;
  }

  case "pair": {
    const edgeId = `mcp-${Date.now().toString(36)}`;
    const deviceName = values.device ?? `mcp-${os.hostname()}`;
    await executePairing(DEFAULT_ENDPOINT, edgeId, deviceName);
    break;
  }

  case "status": {
    const cred = loadDefaultCredential();
    if (cred) {
      console.log(`Paired device: ${cred.deviceName}`);
      console.log(`Credential ID: ${cred.credentialId}`);
      console.log(`Endpoint: ${cred.endpoint}`);
      console.log(`Paired at: ${cred.pairedAt}`);
    } else {
      console.log("No paired device. Run: zhihand pair");
    }
    break;
  }

  case "detect": {
    const tools = await detectCLITools();
    console.log(formatDetectedTools(tools));
    break;
  }

  case "setup": {
    // 1. Check/create pairing
    let cred = loadDefaultCredential();
    if (!cred) {
      console.log("No paired device found. Starting pairing...\n");
      const edgeId = `mcp-${Date.now().toString(36)}`;
      const deviceName = values.device ?? `mcp-${os.hostname()}`;
      await executePairing(DEFAULT_ENDPOINT, edgeId, deviceName);
      cred = loadDefaultCredential();
    }
    if (cred) {
      console.log(`\nPaired: ${cred.deviceName} (${cred.credentialId})\n`);
    }

    // 2. Detect CLI tools
    const tools = await detectCLITools();
    console.log(formatDetectedTools(tools));

    // 3. Auto-configure MCP for detected tools
    let configured = 0;
    for (const tool of tools) {
      try {
        switch (tool.name) {
          case "codex": {
            console.log(`\nConfiguring MCP for Codex...`);
            execSync('codex mcp add zhihand -- zhihand serve', { stdio: 'inherit', timeout: 10000 });
            configured++;
            break;
          }
          case "gemini": {
            console.log(`\nConfiguring MCP for Gemini CLI...`);
            execSync('gemini mcp add --scope user zhihand zhihand -- serve', { stdio: 'inherit', timeout: 10000 });
            configured++;
            break;
          }
          case "claudecode": {
            console.log(`\nConfiguring MCP for Claude Code...`);
            execSync('claude mcp add zhihand -- zhihand serve', { stdio: 'inherit', timeout: 10000 });
            configured++;
            break;
          }
          case "openclaw": {
            await detectAndSetupOpenClaw();
            configured++;
            break;
          }
        }
      } catch (err) {
        console.error(`  Failed to configure ${tool.name}: ${err.message}`);
      }
    }

    if (configured > 0) {
      console.log(`\nSetup complete. Configured ${configured} tool(s).`);
    } else {
      console.log("\nNo tools auto-configured. Add manually to your CLI tool's MCP config:");
      console.log('  { "mcpServers": { "zhihand": { "command": "zhihand", "args": ["serve"] } } }');
    }
    break;
  }

  default:
    console.error(`Unknown command: ${command}. Run 'zhihand --help' for usage.`);
    process.exit(1);
}
